rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regola base: nessun accesso di default
    match /{document=**} {
      allow read, write: if false;
    }

    // Utenti: accesso solo ai propri dati
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;

      // Portfolio: solo l'utente proprietario
      match /portfolio/{assetId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      // Storico vendite: solo l'utente proprietario
      match /historical_sales/{saleId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }
    }
  }
}
